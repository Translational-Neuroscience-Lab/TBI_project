function [epochs, fs, channelLabels, metadata] = loadAndEpochEEG(filepath)
    % Load and epoch mouse EEG data from EDF file
    % Loads first 3 channels (EEG1, EEG2, EMG) with fixed 400 Hz sampling rate
    % 
    % Inputs:
    %   filepath - string, path to .edf file
    %
    % Outputs:
    %   epochs - structure with fields for each channel (EEGEEG1A_B, EEGEEG2A_B, EMGEMG)
    %            each containing cell array of 10-second epochs
    %   fs - sampling frequency (400 Hz)
    %   channelLabels - cell array of loaded channel names
    %   metadata - structure with recording info
    
    %% Fixed parameters
    fs = 400; % Sampling rate in Hz
    channelsToLoad = [1, 2, 3]; % Load first 3 raw channels (EEG1, EEG2, EMG)
    epochDuration = 10; % seconds
    samplesPerEpoch = fs * epochDuration; % 4000 samples per epoch
    
    %% Load EDF file info
    fprintf('Loading EDF file: %s\n', filepath);
    info = edfinfo(filepath);
    
    % Extract metadata
    metadata.startDate = info.StartDate;
    metadata.startTime = info.StartTime;
    metadata.patient = info.Patient;
    metadata.recording = info.Recording;
    
    % Get channel labels
    channelLabels = info.SignalLabels(channelsToLoad);
    
    fprintf('Loading channels:\n');
    for i = 1:length(channelLabels)
        fprintf('  %d: %s\n', i, channelLabels{i});
    end
    
    %% Calculate number of epochs
    if isduration(info.DataRecordDuration)
        recordDuration = seconds(info.DataRecordDuration);
    else
        recordDuration = info.DataRecordDuration;
    end
    
    totalSamples = info.NumDataRecords * info.NumSamples(channelsToLoad(1));
    numEpochs = floor(totalSamples / samplesPerEpoch);
    totalDuration = totalSamples / fs;
    
    fprintf('\nTotal recording duration: %.2f seconds (%.2f minutes)\n', ...
            totalDuration, totalDuration/60);
    fprintf('Number of complete 10-second epochs: %d\n\n', numEpochs);
    
    %% Initialize epochs structure
    epochs = struct();
    
    %% Process each channel
    fprintf('Processing channels...\n');
    
    for ch = 1:length(channelsToLoad)
        channelName = channelLabels{ch};
        fieldName = matlab.lang.makeValidName(channelName);
        
        fprintf('Reading channel %s...', channelName);
        
        % Read this channel's data
        data = edfread(filepath, 'SelectedSignals', channelName);
        
        % Extract signal data from timetable
        dataFieldNames = fieldnames(data);
        signalFieldIdx = find(~strcmp(dataFieldNames, 'Time'), 1);
        signalData = data.(dataFieldNames{signalFieldIdx});
        
        % Flatten signal data if it's in cell array format (one cell per record)
        if iscell(signalData)
            signalData = cell2mat(signalData);
        end
        
        % Ensure it's a column vector
        if size(signalData, 2) > size(signalData, 1)
            signalData = signalData';
        end
        
        % Initialize epoch cell array for this channel
        epochs.(fieldName) = cell(numEpochs, 1);
        
        % Segment data into epochs
        for i = 1:numEpochs
            startIdx = (i-1) * samplesPerEpoch + 1;
            endIdx = i * samplesPerEpoch;
            epochs.(fieldName){i} = signalData(startIdx:endIdx);
            
            % Progress indicator
            if mod(i, 500) == 0
                fprintf('.');
            end
        end
        
        fprintf(' %d epochs created\n', numEpochs);
    end
    
    fprintf('\nEpoching complete!\n\n');
end

%% Seizure detection based on envelope amplitude
function [detectionResults, epochStats] = detectSeizures(epochs, channelLabels, fs, threshold)
    % Detect potential seizure activity based on envelope amplitude
    % Note: EMG channel is excluded from seizure detection but included in output
    %
    % Inputs:
    %   epochs - structure with epoch data for each channel
    %   channelLabels - cell array of channel names
    %   fs - sampling frequency (Hz)
    %   threshold - (optional) number of standard deviations above mean (default: 5)
    %
    % Outputs:
    %   detectionResults - table with detection results for each epoch
    %   epochStats - structure with detailed statistics for each channel
    
    if nargin < 4
        threshold = 5; % Default: 5 standard deviations above mean
    end
    
    fprintf('Running seizure detection with threshold = %.1f standard deviations above mean...\n', threshold);
    fprintf('Note: EMG channel excluded from seizure detection\n\n');
    
    % Get number of epochs
    firstField = matlab.lang.makeValidName(channelLabels{1});
    numEpochs = length(epochs.(firstField));
    
    % Initialize results table
    epochNumbers = (1:numEpochs)';
    startTimes = (0:numEpochs-1)' * 10;
    
    % Initialize detection arrays for each channel
    detectionResults = table(epochNumbers, startTimes, ...
                            'VariableNames', {'EpochNum', 'StartTime_s'});
    
    epochStats = struct();
    
    %% Process each channel
    for ch = 1:length(channelLabels)
        fieldName = matlab.lang.makeValidName(channelLabels{ch});
        channelEpochs = epochs.(fieldName);
        
        % Check if this is the EMG channel
        isEMG = contains(lower(channelLabels{ch}), 'emg');
        
        if isEMG
            fprintf('Processing channel: %s (EMG - statistics only, no seizure detection)\n', channelLabels{ch});
        else
            fprintf('Processing channel: %s (EEG - with seizure detection)\n', channelLabels{ch});
        end
        
        % Initialize arrays for this channel
        meanEnvelopes = zeros(numEpochs, 1);
        stdEnvelopes = zeros(numEpochs, 1);
        thresholdValues = zeros(numEpochs, 1);
        maxPeaks = zeros(numEpochs, 1);
        peakZScores = zeros(numEpochs, 1);
        isSeizure = false(numEpochs, 1);
        numPeaksExceeded = zeros(numEpochs, 1);
        
        % Process each epoch
        for i = 1:numEpochs
            signal = channelEpochs{i};
            
            % Calculate envelope amplitude using Hilbert transform
            analyticSignal = hilbert(signal);
            envelope = abs(analyticSignal);
            
            % Calculate mean and standard deviation of envelope
            meanEnv = mean(envelope);
            stdEnv = std(envelope);
            meanEnvelopes(i) = meanEnv;
            stdEnvelopes(i) = stdEnv;
            
            % Calculate threshold (mean + N*std)
            thresholdVal = meanEnv + (threshold * stdEnv);
            thresholdValues(i) = thresholdVal;
            
            % Find peaks in the envelope
            [peakValues, peakLocs] = findpeaks(envelope);
            
            if ~isempty(peakValues)
                % Find maximum peak
                maxPeak = max(peakValues);
                maxPeaks(i) = maxPeak;
                
                % Calculate z-score of max peak
                peakZScores(i) = (maxPeak - meanEnv) / stdEnv;
                
                % Count how many peaks exceed threshold
                exceedingPeaks = peakValues > thresholdVal;
                numPeaksExceeded(i) = sum(exceedingPeaks);
                
                % Flag as potential seizure ONLY if NOT EMG channel
                if ~isEMG && maxPeak > thresholdVal
                    isSeizure(i) = true;
                end
            else
                maxPeaks(i) = max(envelope);
                peakZScores(i) = (maxPeaks(i) - meanEnv) / stdEnv;
            end
        end
        
        % Store results in table
        detectionResults.([fieldName '_MeanEnvelope']) = meanEnvelopes;
        detectionResults.([fieldName '_StdEnvelope']) = stdEnvelopes;
        detectionResults.([fieldName '_Threshold']) = thresholdValues;
        detectionResults.([fieldName '_MaxPeak']) = maxPeaks;
        detectionResults.([fieldName '_PeakZScore']) = peakZScores;
        detectionResults.([fieldName '_NumPeaksExceeded']) = numPeaksExceeded;
        
        % Only add seizure flag for non-EMG channels
        if ~isEMG
            detectionResults.([fieldName '_SeizureFlag']) = isSeizure;
        end
        
        % Store detailed statistics
        epochStats.(fieldName).meanEnvelopes = meanEnvelopes;
        epochStats.(fieldName).stdEnvelopes = stdEnvelopes;
        epochStats.(fieldName).thresholdValues = thresholdValues;
        epochStats.(fieldName).maxPeaks = maxPeaks;
        epochStats.(fieldName).peakZScores = peakZScores;
        epochStats.(fieldName).numPeaksExceeded = numPeaksExceeded;
        
        if ~isEMG
            epochStats.(fieldName).isSeizure = isSeizure;
            epochStats.(fieldName).numSeizureEpochs = sum(isSeizure);
            epochStats.(fieldName).seizureEpochIndices = find(isSeizure);
            fprintf('  Detected %d potential seizure epochs (%.1f%%)\n', ...
                    sum(isSeizure), 100*sum(isSeizure)/numEpochs);
        else
            fprintf('  Statistics calculated (no seizure detection for EMG)\n');
        end
    end
    
    fprintf('\nDetection complete!\n\n');
end

%% Visualization function for detection results
function visualizeDetectionResults(epochs, channelLabels, detectionResults, fs, epochsToShow, thresholdValue)
    % Visualize epochs with seizure detections
    %
    % Inputs:
    %   epochs - structure with epoch data
    %   channelLabels - cell array of channel names
    %   detectionResults - table with detection results
    %   fs - sampling frequency
    %   epochsToShow - (optional) specific epoch indices to display, or 'seizures' to show flagged epochs
    %   thresholdValue - (optional) threshold multiplier to display (default: 3)
    
    if nargin < 5
        epochsToShow = 'seizures';
    end
    
    if nargin < 6
        thresholdValue = 3; % Default threshold
    end
    
    % Determine which epochs to display
    if ischar(epochsToShow) && strcmp(epochsToShow, 'seizures')
        % Show epochs flagged as seizures in any channel
        seizureFlags = false(height(detectionResults), 1);
        for ch = 1:length(channelLabels)
            fieldName = matlab.lang.makeValidName(channelLabels{ch});
            flagCol = [fieldName '_SeizureFlag'];
            if ismember(flagCol, detectionResults.Properties.VariableNames)
                seizureFlags = seizureFlags | detectionResults.(flagCol);
            end
        end
        epochsToShow = find(seizureFlags);
        
        if isempty(epochsToShow)
            fprintf('No seizure epochs detected to display.\n');
            return;
        end
        
        % Limit to first 6 seizure epochs for visualization
        epochsToShow = epochsToShow(1:min(6, length(epochsToShow)));
    end
    
    numEpochs = length(epochsToShow);
    numChannels = length(channelLabels);
    timeVector = (0:(fs*10)-1) / fs;
    
    figure('Position', [100, 100, 1400, 300*numEpochs]);
    
    for idx = 1:numEpochs
        epochNum = epochsToShow(idx);
        
        for ch = 1:numChannels
            fieldName = matlab.lang.makeValidName(channelLabels{ch});
            signal = epochs.(fieldName){epochNum};
            
            % Calculate envelope
            envelope = abs(hilbert(signal));
            
            % Get mean envelope and threshold
            meanEnvCol = [fieldName '_MeanEnvelope'];
            thresholdCol = [fieldName '_Threshold'];
            
            if ismember(meanEnvCol, detectionResults.Properties.VariableNames)
                meanEnv = detectionResults.(meanEnvCol)(epochNum);
            else
                meanEnv = mean(envelope); % Calculate if not in results
            end
            
            if ismember(thresholdCol, detectionResults.Properties.VariableNames)
                thresholdLine = detectionResults.(thresholdCol)(epochNum);
            else
                % Calculate threshold if not in results
                stdEnv = std(envelope);
                thresholdLine = meanEnv + (thresholdValue * stdEnv);
            end
            
            subplotIdx = (idx-1)*numChannels + ch;
            subplot(numEpochs, numChannels, subplotIdx);
            
            % Plot signal
            plot(timeVector, signal, 'b', 'LineWidth', 0.5);
            hold on;
            
            % Plot envelope
            plot(timeVector, envelope, 'r', 'LineWidth', 1);
            
            % Plot mean envelope line
            plot([0 10], [meanEnv meanEnv], 'g--', 'LineWidth', 1.5);
            
            % Plot threshold line
            plot([0 10], [thresholdLine thresholdLine], 'm--', 'LineWidth', 1.5);
            
            xlabel('Time (s)');
            ylabel('Amplitude (\muV)');
            
            % Check if this channel has seizure flag (EMG won't have it)
            flagCol = [fieldName '_SeizureFlag'];
            if ismember(flagCol, detectionResults.Properties.VariableNames)
                isSeizure = detectionResults.(flagCol)(epochNum);
                zScoreCol = [fieldName '_PeakZScore'];
                
                if ismember(zScoreCol, detectionResults.Properties.VariableNames)
                    zScore = detectionResults.(zScoreCol)(epochNum);
                    titleStr = sprintf('Epoch %d - %s (Z-score: %.2f)', epochNum, channelLabels{ch}, zScore);
                else
                    titleStr = sprintf('Epoch %d - %s', epochNum, channelLabels{ch});
                end
                
                if isSeizure
                    titleStr = [titleStr ' - SEIZURE DETECTED'];
                    title(titleStr, 'Color', 'r', 'FontWeight', 'bold');
                else
                    title(titleStr);
                end
            else
                % EMG channel - no seizure detection
                zScoreCol = [fieldName '_PeakZScore'];
                if ismember(zScoreCol, detectionResults.Properties.VariableNames)
                    zScore = detectionResults.(zScoreCol)(epochNum);
                    titleStr = sprintf('Epoch %d - %s (Z-score: %.2f) - EMG', epochNum, channelLabels{ch}, zScore);
                else
                    titleStr = sprintf('Epoch %d - %s - EMG', epochNum, channelLabels{ch});
                end
                title(titleStr, 'Color', 'k');
            end
            
            legend('Signal', 'Envelope', 'Mean Env', sprintf('Mean + %.1f SD', thresholdValue), 'Location', 'best');
            grid on;
            xlim([0 10]);
            hold off;
        end
    end
    
    sgtitle('Seizure Detection Results');
end

%% Summary statistics function
function displayDetectionSummary(detectionResults, channelLabels)
    % Display summary of detection results (excluding EMG)
    
    fprintf('\n========== SEIZURE DETECTION SUMMARY ==========\n\n');
    
    for ch = 1:length(channelLabels)
        fieldName = matlab.lang.makeValidName(channelLabels{ch});
        flagCol = [fieldName '_SeizureFlag'];
        
        % Check if this channel has seizure detection (EMG won't)
        if ~ismember(flagCol, detectionResults.Properties.VariableNames)
            fprintf('Channel: %s (EMG - no seizure detection)\n\n', channelLabels{ch});
            continue;
        end
        
        numSeizures = sum(detectionResults.(flagCol));
        totalEpochs = height(detectionResults);
        percentage = 100 * numSeizures / totalEpochs;
        
        fprintf('Channel: %s\n', channelLabels{ch});
        fprintf('  Total epochs: %d\n', totalEpochs);
        fprintf('  Seizure epochs: %d (%.1f%%)\n', numSeizures, percentage);
        
        if numSeizures > 0
            seizureEpochs = find(detectionResults.(flagCol));
            fprintf('  Seizure epoch numbers: ');
            if numSeizures <= 20
                fprintf('%s\n', mat2str(seizureEpochs'));
            else
                fprintf('%s ... (showing first 20)\n', mat2str(seizureEpochs(1:20)'));
            end
        end
        fprintf('\n');
    end
    
    fprintf('===============================================\n\n');
end

%% Main execution example
function visualizeEpochs(epochs, channelLabels, fs, numEpochsToPlot)
    % Visualize specified number of epochs for all channels
    
    if nargin < 4
        numEpochsToPlot = min(4, length(epochs.(matlab.lang.makeValidName(channelLabels{1}))));
    end
    
    numChannels = length(channelLabels);
    timeVector = (0:(fs*10)-1) / fs;
    
    figure('Position', [100, 100, 1400, 300*numEpochsToPlot]);
    
    for epochNum = 1:numEpochsToPlot
        for ch = 1:numChannels
            fieldName = matlab.lang.makeValidName(channelLabels{ch});
            
            subplotIdx = (epochNum-1)*numChannels + ch;
            subplot(numEpochsToPlot, numChannels, subplotIdx);
            
            plot(timeVector, epochs.(fieldName){epochNum}, 'b', 'LineWidth', 0.5);
            xlabel('Time (s)');
            ylabel('Amplitude (\muV)');
            title(sprintf('Epoch %d - %s', epochNum, channelLabels{ch}));
            grid on;
            xlim([0 10]);
        end
    end
    
    sgtitle('EEG Epochs - All Channels (10 seconds each)');
end

%% Function to convert epochs to table format (multi-channel)
function epochTable = epochsToTable(epochs, channelLabels, fs)
    % Convert epochs to table format with statistics for all channels
    
    % Get number of epochs from first channel
    firstField = matlab.lang.makeValidName(channelLabels{1});
    numEpochs = length(epochs.(firstField));
    
    epochNumbers = (1:numEpochs)';
    startTimes = (0:numEpochs-1)' * 10;
    endTimes = (1:numEpochs)' * 10;
    
    % Initialize table
    epochTable = table(epochNumbers, startTimes, endTimes, ...
                       'VariableNames', {'EpochNum', 'StartTime_s', 'EndTime_s'});
    
    % Add statistics for each channel
    for ch = 1:length(channelLabels)
        fieldName = matlab.lang.makeValidName(channelLabels{ch});
        channelEpochs = epochs.(fieldName);
        
        % Calculate statistics
        meanAmp = cellfun(@mean, channelEpochs);
        stdAmp = cellfun(@std, channelEpochs);
        maxAmp = cellfun(@max, channelEpochs);
        minAmp = cellfun(@min, channelEpochs);
        
        % Add to table with channel name prefix
        epochTable.([fieldName '_Mean']) = meanAmp;
        epochTable.([fieldName '_Std']) = stdAmp;
        epochTable.([fieldName '_Max']) = maxAmp;
        epochTable.([fieldName '_Min']) = minAmp;
        epochTable.([fieldName '_Data']) = channelEpochs;
    end
end

